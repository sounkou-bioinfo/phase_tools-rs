        given-names: Adrian
      - family-names: Abecasis
        given-names: Gonçalo R.
      - family-names: Kang
        given-names: Hyun Min
    journal: Bioinformatics
    year: 2015
    volume: 31
    issue: 13
    start: 2202
    end: 2204
    doi: 10.1093/bioinformatics/btv112
    url: https://doi.org/10.1093/bioinformatics/btv112
